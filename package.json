{
  "name": "spacecandy",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~56.0.12",
    "expo-dev-client": "^56.0.20",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "scripts": {
    "start": "expo start --dev-client --lan",
    "dev": "expo start --dev-client --lan --port 8081",
    "expo-go": "expo start --go --lan --port 8081",
    "android": "expo start --dev-client --android",
    "ios": "expo start --dev-client --ios",
    "web": "expo start --web",
    "eas:login": "npx eas-cli login",
    "build:dev:android": "npx eas-cli build --platform android --profile development",
    "build:dev:ios-simulator": "npx eas-cli build --platform ios --profile development-simulator",
    "build:dev:ios-device": "npx eas-cli build --platform ios --profile development-device"
  },
  "private": true
}
